    "@fontsource/jetbrains-mono": "^5.0.0",
    "@mantine/core": "^7.11.0",
    "@mantine/form": "7.17.8",
    "@mantine/hooks": "^7.11.0",
    "@mantine/notifications": "^7.11.0",
    "@mantine/spotlight": "^7.11.0",
    "@tanstack/react-query": "^5.50.0",
    "@tanstack/react-router": "^1.45.0",
    "decimal.js": "^10.4.3",
    "openapi-fetch": "^0.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuidv7": "^1.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@tanstack/router-plugin": "^1.45.0",
    "@testing-library/dom": "^10.4.1",
