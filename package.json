{
  "name": "ilex-inventory-client",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run lint:gates",
    "lint:gates": "bash scripts/check-grep-gates.sh",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "generate:api": "node scripts/generate-api.mjs"
  },
  "dependencies": {
