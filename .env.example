# Required: Server origin + /api/v1/ path (SPEC §2.10)
# App refuses to start if this is missing.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional: Source for OpenAPI type generation (used by npm run generate:api in issue 002)
# The BE drf-spectacular emits the schema at this path.
VITE_OPENAPI_URL=http://localhost:8000/api/v1/openapi.json

# Optional: Sentry DSN for error reporting (leave unset in dev)
# VITE_SENTRY_DSN=

# Optional: E2E test base URL (Playwright baseURL — default http://localhost:5173)
# Change if you run the Vite dev server on a different port or host.
# VITE_E2E_BASE_URL=http://localhost:5173

# Optional: Vite dev-server proxy target (default http://localhost:8000)
# Set to your BE server origin. The Vite dev server proxies /api/* to this target.
# Required for local E2E runs where the BE is on a non-default port.
# VITE_API_PROXY_TARGET=http://localhost:8000
